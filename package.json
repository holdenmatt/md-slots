{
  "name": "md-slots",
  "version": "0.1.0",
  "description": "Tiny {{slot}} renderer for markdown text.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "check": "pnpm lint && pnpm test && pnpm build"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
